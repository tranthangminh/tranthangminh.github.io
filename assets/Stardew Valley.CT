              <CheatEntries>
                <CheatEntry>
                  <ID>124286</ID>
                  <Description>"Refresh Structures (use this if pointers do not show correct address)"</Description>
                  <LastState/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
if syntaxcheck then return end
function updateToolStructure()
    local baseAddr = getAddressSafe('[baseTool]')
    local struct1 = getStructureByName('Tool')
    local struct2 = getStructureByName('Weapon')
    local struct = createStructure('temp')
    struct.fillFromDotNetAddress(baseAddr,true)
    if struct.Name == 'StardewValley.Tools.MeleeWeapon' then
        struct.Name = 'Weapon'
        if struct2 then struct2.destroy() end
    else
        struct.Name = 'Tool'
        if struct1 then struct1.destroy() end
    end
    struct.addToGlobalStructureList()
end
local unCheckMe=createTimer()
unCheckMe.Interval=100
unCheckMe.OnTimer=function()
   memrec.Active=false
   unCheckMe.destroy()
end
[ENABLE]
updateToolStructure()
[DISABLE]

</AssemblerScript>

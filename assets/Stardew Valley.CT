//Unique AOB: 8B 45 E4 88 83 ? ? ? ? 8B 45 ? 89 83
//define(fishModifier,StardewValley.Tools.FishingRod::doPullFishFromWater+8F)
[ENABLE]
aobscan(fishModifier,8B 45 E4 88 83 ? ? ? ? 8B 45 ? 89 83)
registersymbol(fishModifier)
registersymbol(newfishModifier)
registersymbol(codefishModifier)
registersymbol(fishSizeVal)
registersymbol(fishQualityVal)
registersymbol(fishTypeVal)
registersymbol(bEnableTreasure)
alloc(newfishModifier,200,fishModifier)
label(codefishModifier)
label(fishSizeVal)
label(fishQualityVal)
label(fishTypeVal)
label(bEnableTreasure)
newfishModifier:
	cmp [bEnableTreasure],0
    je @f
	xor eax,eax
    inc eax
    mov [ebp-1C],eax
@@:
	cmp [fishSizeVal],0
    je @f
    fild [fishSizeVal]
    fistp [ebp-14]
@@:
	cmp [fishTypeVal],0
    je @f
    fild [fishTypeVal]
    fistp [ebp-10]
@@:
	cmp [fishQualityVal],0
    je codefishModifier
    mov edi,[fishQualityVal]
codefishModifier:
	readmem(fishModifier,9)
	ret
fishSizeVal:
  dd 0
fishQualityVal:
  dd 0
fishTypeVal:
  dd 0
bEnableTreasure:
  db 0
fishModifier:
	call newfishModifier
	nop 4

[DISABLE]
fishModifier:
	readmem(codefishModifier,9)

unregistersymbol(fishModifier)
unregistersymbol(newfishModifier)
unregistersymbol(codefishModifier)
unregistersymbol(fishSizeVal)
unregistersymbol(fishQualityVal)
unregistersymbol(fishTypeVal)
unregistersymbol(bEnableTreasure)
dealloc(newfishModifier)


                  <AssemblerScript>{$lua}
if syntaxcheck then return end
function updateObjectStructure()
    local baseAddr = getAddressSafe('[baseItem]')
    local struct1 = getStructureByName('Object')
    if struct1 then struct1.destroy() end
    local struct = createStructure('Object')
    struct.fillFromDotNetAddress(baseAddr,false)
    struct.addToGlobalStructureList()
end
local unCheckMe=createTimer()
unCheckMe.Interval=100
unCheckMe.OnTimer=function()
   memrec.Active=false
   unCheckMe.destroy()
end
[ENABLE]
updateObjectStructure()
[DISABLE]


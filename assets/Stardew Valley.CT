    <CheatEntry>
      <ID>124313</ID>
      <Description>"SOURCE: https://fearlessrevolution.com/viewtopic.php?t=14816"</Description>
      <Options moManualExpandCollapse="1" moAllowManualCollapseAndExpand="1"/>
      <LastState Value="" RealAddress="00000000"/>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>124312</ID>
          <Description>"Enable"</Description>
          <Options moManualExpandCollapse="1" moAllowManualCollapseAndExpand="1"/>
          <LastState Activated="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">{$lua}
if syntaxcheck then return end
function getStructureByName(structName)
	local numStructs = getStructureCount() - 1
	for i = 0,numStructs do
		local struct = getStructure(i)
		if struct.Name == structName then return struct end
	end
	return nil
end
[ENABLE]
symbolTimer = createTimer()
symbolTimer.Inverval = 5000
symbolTimer.OnTimer = function()
	reinitializeSymbolhandler(true)
end
[DISABLE]
symbolTimer.destroy()
</AssemblerScript>
          <CheatEntries>
            <CheatEntry>
              <ID>124051</ID>
              <Description>"Get Farmer Pointers"</Description>
              <Options moManualExpandCollapse="1" moAllowManualCollapseAndExpand="1"/>
              <LastState/>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{
	Game	: Stardew Valley.exe
	Version	: 1.5.1
	Date	: 2021-01-02
	Author	: aSwedishMagyar
}
define(getPlayer,StardewValley.Farmer::get__money)
[ENABLE]
assert(getPlayer,55 8B EC 8B D1 8B 82 5C)
registersymbol(playerBase)
alloc(newgetPlayer,100,getPlayer)
label(codegetPlayer)
label(returngetPlayer)
label(playerBase)
newgetPlayer:
  mov [playerBase],ecx
codegetPlayer:
  push ebp
  mov ebp,esp
  mov edx,ecx
  jmp returngetPlayer
playerBase:
  dd 0
getPlayer:
  jmp newgetPlayer
returngetPlayer:

[DISABLE]
getPlayer:
  db 55 8B EC 8B D1

unregistersymbol(playerBase)
dealloc(newgetPlayer)
</AssemblerScript>
              <CheatEntries>
                <CheatEntry>
                  <ID>124285</ID>
                  <Description>"Refresh Structures (use this if pointers do not show correct address)"</Description>
                  <LastState/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
if syntaxcheck then return end
local nameList = {{'Farmer','[playerBase]'},{'teamRoot','[[playerBase]+Farmer.teamRoot]'},{'Team','[[[playerBase]+Farmer.teamRoot]+teamRoot.value]'},{'netInt','[[[[playerBase]+Farmer.teamRoot]+teamRoot.value]+Team.money]'}}
function updateFarmerStructure()
    for i = 1,#nameList do
    local struct = getStructureByName(nameList[i][1])
    local new = true
    if struct then new = false end
    local baseAddr = getAddressSafe(nameList[i][2])
    struct = createStructure(nameList[i][1])
    struct.fillFromDotNetAddress(baseAddr,false)
    if new then struct.addToGlobalStructureList() end
    end
end
local unCheckMe=createTimer()
unCheckMe.Interval=100
unCheckMe.OnTimer=function()
   memrec.Active=false
   unCheckMe.destroy()
end
[ENABLE]
updateFarmerStructure()
[DISABLE]

</AssemblerScript>

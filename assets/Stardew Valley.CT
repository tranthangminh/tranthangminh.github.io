if syntaxcheck then return end
function updateToolStructure()
    local baseAddr = getAddressSafe('[baseCart]')
    local struct = getStructureByName('Cart')
    if struct then struct.destroy() end
    struct = createStructure('Cart')
    struct.fillFromDotNetAddress(baseAddr,false)
    struct.addToGlobalStructureList()
    local struct2 = getStructureByName('Player')
    if struct2 then struct2.destroy() end
    local basePlayer = getAddressSafe('[[baseCart]+Cart.player]')
    struct2 = createStructure('Player')
    struct2.fillFromDotNetAddress(basePlayer)
    struct2.addToGlobalStructureList()
end
local unCheckMe=createTimer()
unCheckMe.Interval=100
unCheckMe.OnTimer=function()
   memrec.Active=false
   unCheckMe.destroy()
end
[ENABLE]
updateToolStructure()
[DISABLE]

</AssemblerScript>

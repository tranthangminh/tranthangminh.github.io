codeCastleLevel:
 push ebx
 lea ebx,[rdx+rcx*4+20] //Save rdx+rcx*4+20 address into eax
 mov [CastleLevel],ebx //Save eax address into CastleLevel
 pop ebx

 mov eax,[rdx+rcx*4+20]
 xor edx,edx
 jmp returnCastleLevel

addressCastleLevel:
 jmp newmemCastleLevel
 nop
returnCastleLevel:








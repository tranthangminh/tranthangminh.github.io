//MasteryPoints
define(addressMasteryPoints,"GameAssembly.dll"+44C442)
define(bytesMasteryPoints,41 03 1C 00 FF C2)






[ENABLE]

//==============================Gold

assert(addressGold,bytesGold)
alloc(newmemGold,$1000,"GameAssembly.dll"+BFD527)

alloc(Gold,4)
registersymbol(Gold)

label(codeGold)
label(returnGold)

newmemGold:

codeGold:
 mov [Gold],rax
 addsd xmm0,[rax+10]
 jmp returnGold

addressGold:
 jmp newmemGold
returnGold:

//==============================Amber

assert(addressAmber,bytesAmber)
alloc(newmemAmber,$1000,"GameAssembly.dll"+BF5140)

alloc(Amber,4)
registersymbol(Amber)

label(codeAmber)
label(returnAmber)

newmemAmber:

codeAmber:
 mov [Amber],rax
 mov eax,[rax+24]
 add rsp,28
 jmp returnAmber

addressAmber:
 jmp newmemAmber
 nop 2
returnAmber:


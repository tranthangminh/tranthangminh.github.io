alloc(MasteryPoints,4)
registersymbol(MasteryPoints)

label(codeMasteryPoints)
label(returnMasteryPoints)

newmemMasteryPoints:

codeMasteryPoints:
 push ebx
 lea ebx,[r8+rax] //Save r8+rax address into ebx
 mov [MasteryPoints],ebx //Save ebx address into MasteryPoints
 pop ebx

 add ebx,[r8+rax]
 inc edx
 jmp returnMasteryPoints

addressMasteryPoints:
 jmp newmemMasteryPoints
 nop
returnMasteryPoints:








        <CheatEntry>
          <ID>16292</ID>
          <Description>"Get Stats in Conquest     ・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・"</Description>

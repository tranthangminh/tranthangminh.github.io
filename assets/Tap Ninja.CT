          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>//Gold
define(addressGold,"GameAssembly.dll"+BFD527)
define(bytesGold,F2 0F 58 40 10)

//Amber
define(addressAmber,"GameAssembly.dll"+BF5140)
define(bytesAmber,8B 40 24 48 83 C4 28)

//Elixir
define(addressElixir,"GameAssembly.dll"+BF97B6)
define(bytesElixir,F2 0F 10 40 18)

//Key
define(addressKey,"GameAssembly.dll"+BFCD78)
define(bytesKey,66 0F 6E 4A 30)

//Medal
define(addressMedal,"GameAssembly.dll"+BF5CD6)
define(bytesMedal,8B 40 38 48 83 C4 28)

//Dash
define(addressDash,"GameAssembly.dll"+F6750E)
define(bytesDash,F3 0F 10 80 74 02 00 00)

//RopeHook
define(addressRopeHook,"GameAssembly.dll"+F66B7E)
define(bytesRopeHook,F3 0F 10 80 30 02 00 00)

//ShurikenVortex
define(addressShurikenVortex,"GameAssembly.dll"+F66EF4)
define(bytesShurikenVortex,F3 0F 10 80 F0 01 00 00)

//QuestBoardProgress
define(addressQuestBoardProgress,"GameAssembly.dll"+CFCBD4)
define(bytesQuestBoardProgress,66 0F 6E 88 0C 05 00 00)

//HolidayTasks

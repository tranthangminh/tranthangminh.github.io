//HP - //INJECTION HERE: ViceCity.exe.text+112E441
define(addressHP,ViceCity.exe.text+112E441)

//Armor - //INJECTION HERE: ViceCity.exe.text+11A047B
define(addressArmor,ViceCity.exe.text+11A047B)






[ENABLE]

//──────────────────────────────────────── HP
//INJECTION HERE: ViceCity.exe.text+112E441

alloc(newmemHP,$1000,ViceCity.exe.text+112E441)

alloc(HP,8)
registersymbol(HP)
label(codeHP)
label(returnHP)

newmemHP:

codeHP:
 mov [HP],rdx //Save rdx address into HP
 comiss xmm9,[rdx+000004E4]
 jmp returnHP

addressHP:
 jmp newmemHP
 nop 3
returnHP:

//──────────────────────────────────────── Armor
//INJECTION HERE: ViceCity.exe.text+11A047B

alloc(newmemArmor,$1000,ViceCity.exe.text+11A047B)

alloc(Armor,8)
registersymbol(Armor)
label(codeArmor)
label(returnArmor)

newmemArmor:

codeArmor:
 mov [Armor],r12 //Save r12 address into Armor
 movss xmm0,[r12+000004E8]
 jmp returnArmor

addressArmor:
 jmp newmemArmor
 nop 5
returnArmor:







[DISABLE]

//──────────────────────────────────────── HP
//INJECTION HERE: ViceCity.exe.text+112E441

addressHP:
 comiss xmm9,[rdx+000004E4]

dealloc(newmemHP)
dealloc(HP)
unregistersymbol(HP)

//──────────────────────────────────────── Armor
//INJECTION HERE: ViceCity.exe.text+11A047B

addressArmor:
 movss xmm0,[r12+000004E8]

dealloc(newmemArmor)
dealloc(Armor)
unregistersymbol(Armor)
</AssemblerScript>

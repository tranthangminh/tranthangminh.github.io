define(address2,Gameplay.GameControllers.Penitent.Abilities:Parry:OnUpdate)
define(bytes2,55 48 8B EC 56)

define(address3,Gameplay.GameControllers.Penitent:Penitent:Damage)
define(bytes3,55 48 8B EC 56)

[ENABLE]

{$lua}
--Based on TheyCallMeTim13's lua keylistener script -&gt; thx for this!
--http://fearlessrevolution.com/viewtopic.php?f=4&amp;t=6041&amp;start=60#p62657
local function CheckParryThread(thread2)
	local addr2 = getAddressSafe('bParryActiv')
    local addchance = getAddressSafe('dParryChance')
    local addchanceactiv = getAddressSafe('bChanceActiv')
    local keycode = getAddressSafe('dAutoKey')
    local KeyPressed
	while runCheckParryThread do
        sleep(100)
        KeyPressed = 0
		if addr2 and addchance and addchanceactiv then
            if ( isKeyPressed(readInteger(keycode))) then
			    writeBytes(addr2, 1)
                KeyPressed = 1
            else
                writeBytes(addr2, 0)
            end

            if readBytes(addchanceactiv,0x01) == 0x01 and KeyPressed == 0 then
               if (math.random(1,100) &lt;= readInteger(addchance))then
                              writeBytes(addr2, 1)

                          else
                              writeBytes(addr2, 0)
                          end
            end

		else
			addr2 = getAddressSafe('bParryActiv')
            addchance = getAddressSafe('dParryChance')
            addchanceactiv = getAddressSafe('bChanceActiv')
            keycode = getAddressSafe('dAutoKey')
		end
	end
	thread2.terminate()
end
----------------------------------
if syntaxcheck then return end
runCheckParryThread = true
createThread(CheckParryThread)
{$asm}

//

aobscanregion(aobInvFlag,Gameplay.GameControllers.Penitent.Abilities:Parry:ParrySuccess,Gameplay.GameControllers.Penitent.Abilities:Parry:ParrySuccess+150,C6 40 11 01) // should be unique

aobInvFlag+3:
  db 00 // EntityStatus0x11 = Inv

//

registersymbol(aobInvFlag)

assert(address2,bytes2)
alloc(newmem2,$1000,Gameplay.GameControllers.Penitent.Abilities:Parry:OnUpdate)

label(code2)
label(return2)

newmem2:

code2:
  push rbp
  mov rbp,rsp
  push rsi
  mov byte ptr[rcx+B4],00 // SuccessParry
  jmp return2

address2:
  jmp newmem2
return2:
//

assert(address3,bytes3)
alloc(newmem3,$1000,Gameplay.GameControllers.Penitent:Penitent:Damage)

label(code3)
label(return3)

newmem3:

code3:
  push rbp
  mov rbp,rsp
  push rsi
  mov rsi,[rcx+158] // parry
  push rax
  mov rax,bParryActiv
  cmp byte ptr[rax],0
  pop rax
   je return3
  mov byte ptr[rsi+B5],01 // IsOnParryChance
  jmp return3

address3:
  jmp newmem3
return3:

[DISABLE]


{$lua}
if syntaxcheck then return end
runCheckParryThread = false
{$asm}

aobInvFlag+3:
  db 01

unregistersymbol(aobInvFlag)


//aobSetParryStatus:
  //db 0F B6 86 B5 00 00 00

//unregistersymbol(aobSetParryStatus)
address2:
  db bytes2
  // push rbp
  // mov rbp,rsp
  // push rsi

dealloc(newmem2)

address3:
  db bytes3
  // push rbp
  // mov rbp,rsp
  // push rsi

dealloc(newmem3)


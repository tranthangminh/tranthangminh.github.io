define(address,CreativeSpore.SmartColliders:PlatformCharacterController:Update )
define(bytes,55 48 8B EC 56)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,CreativeSpore.SmartColliders:PlatformCharacterController:Update )

label(code)
label(return)
label(isActiv)
registersymbol(isActiv)
label(fSpeed)
registersymbol(fSpeed)

newmem:

code:
  push rbp
  mov rbp,rsp
  push rsi

  mov rsi,[fSpeed]
  mov [rcx+7C],esi

  push rcx
  cmp [isActiv],1
  je DoubleJump
  add rcx,18
  mov rcx,[rcx]
  mov [rcx+40],(float)3
  jmp jOut

  DoubleJump:
  mov [rcx+A4],0
  add rcx,18
  mov rcx,[rcx]
  movss xmm0,[rcx+20]
  mov rsi,fMax
  movss xmm1,[rsi]
  maxss xmm0,xmm1
  movss [rcx+20],xmm0

  jOut:
  pop rcx
  jmp return
isActiv:
dd 0
fSpeed:
dd (float)1.75
fMax:
dd (float)-10

address:
  jmp newmem
return:

[DISABLE]
{$lua}
default = getAddress('[pPlat]+40')
writeFloat(default,3.0)
{$asm}

address:
  db bytes
  // push rbp
  // mov rbp,rsp
  // push rsi

dealloc(newmem)


label(vehicleDamage2Ret)
label(fDamageExplodeRet)

newmem:
cmp [playerVehicle],rbx
jne @f
mov [rbx+000006C4],(float)1000
jmp return
@@:
movss [rbx+000006C4],xmm0
jmp return

vehicleDamage2:
cmp [playerVehicle],rbx
jne @f
mov [rbx+000006C4],(float)1000
jmp vehicleDamage2Ret
@@:
movss [rbx+000006C4],xmm0
jmp vehicleDamage2Ret

fDamageExplode:
cmp [playerVehicle],rcx
jne @f
ret
@@:
movss [rsp+20],xmm3
jmp fDamageExplodeRet

get_vehicleDamage1:
  jmp newmem
  nop 3
return:
registersymbol(get_vehicleDamage1)

get_vehicleDamage2:
  jmp vehicleDamage2
  nop 3
vehicleDamage2Ret:
registersymbol(get_vehicleDamage2)

get_damageExplode:
  jmp fDamageExplode
  nop
fDamageExplodeRet:
registersymbol(get_damageExplode)

get_damageWhenFlipped:
db 90 90 90 90 90 90 90 90


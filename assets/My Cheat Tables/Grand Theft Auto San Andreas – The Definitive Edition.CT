              <Color>FF8000</Color>
              <GroupHeader>1</GroupHeader>
              <CheatEntries>
                <CheatEntry>
                  <ID>14</ID>
                  <Description>"Infinite Health"</Description>
                  <LastState/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
aobscanmodule(get_doDamage,SanAndreas.exe,48 89 5C 24 08 48 89 6C 24 10 48 89 74 24 18 57 48 83 EC 50 83)
alloc(newmem,$1000,get_doDamage)
label(return)

newmem:
cmp rbx,[Player]
jne @f
mov eax,[rbx+00000708]
mov [rcx+08],0
mov [rbx+00000704],eax
@@:
mov [rsp+08],rbx
jmp return

get_doDamage:
  jmp newmem
return:
registersymbol(get_doDamage)

[DISABLE]
get_doDamage:
  db 48 89 5C 24 08

unregistersymbol(get_doDamage)
dealloc(newmem)
</AssemblerScript>
                </CheatEntry>
                <CheatEntry>
                  <ID>11</ID>
                  <Description>"Infinite Armor"</Description>
                  <LastState/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
aobscanmodule(get_Armor,SanAndreas.exe,F3 0F 10 83 0C 07 00 00) //When taking damage, set to max
aobscanmodule(get_noArmor,SanAndreas.exe,0F 2F A6 0C 07 00 00) //Also always set to max, in case you have none
alloc(newmem,$1000,get_Armor)
label(return)
label(NoArmor)
label(NoArmorRet)

newmem:
cmp rbx,[Player]
jne @f
mov [rbx+0000070C],(float)100
mov [r14+08],0
@@:
movss xmm0,[rbx+0000070C]
jmp return

NoArmor:
cmp rbx,[Player]
jne @f
mov [rsi+0000070C],(float)100
@@:
comiss xmm4,[rsi+0000070C]
jmp NoArmorRet

get_Armor:
  jmp newmem
  nop 3
return:
registersymbol(get_Armor)

get_noArmor:
  jmp NoArmor
  nop 2
NoArmorRet:
registersymbol(get_noArmor)

[DISABLE]
get_Armor:
  db F3 0F 10 83 0C 07 00 00

get_noArmor:
  db 0F 2F A6 0C 07 00 00

unregistersymbol(get_Armor)
unregistersymbol(get_noArmor)
dealloc(newmem)


                  <ID>31</ID>
                  <Description>"Infinite Vehicle Health (Damage, will never explode)"</Description>
                  <LastState/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
aobscanmodule(get_vehicleDamage1,SanAndreas.exe,F3 0F 11 83 C4 06 00 00 44)
aobscanmodule(get_vehicleDamage2,SanAndreas.exe,F3 0F 11 83 C4 06 00 00 85)
aobscanmodule(get_damageWhenFlipped,SanAndreas.exe,F3 0F 11 80 C4 06 00 00 49)
aobscanmodule(get_damageExplode,SanAndreas.exe,F3 0F 11 5C 24 20 55 53 57)
registersymbol(get_damageWhenFlipped)

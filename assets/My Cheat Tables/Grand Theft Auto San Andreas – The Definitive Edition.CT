                <CheatEntry>
                  <ID>317</ID>
                  <Description>"Rapid Fire"</Description>
                  <LastState/>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
aobscanmodule(get_fireRateStanding,SanAndreas.exe,F3 45 0F 10 40 48)
aobscanmodule(get_fireRateCrouch,SanAndreas.exe,F3 45 0F 10 40 54)
alloc(fireRateStanding,$1000,get_fireRateStanding)
alloc(fireRateCrouch,$1000,get_fireRateCrouch)
label(fireRateStandingRet)
label(fireRateCrouchRet)
globalalloc(isActive,1)

isActive:
db 01

fireRateStanding:
cmp rdi,[Player]
jne @f
sub rsp,04
mov [rsp],(float)0.11
movss xmm6,[rsp]
movss xmm8,[rsp]
mov [rsp],(float)0.15
movss xmm10,[rsp]
add rsp,04
jmp fireRateStandingRet
@@:
movss xmm6,[r8+40]
movss xmm10,[r8+44]
movss xmm8,[r8+48]
jmp fireRateStandingRet

fireRateCrouch:
cmp rdi,[Player]
jne @f
sub rsp,04
mov [rsp],(float)0.11
movss xmm6,[rsp]
movss xmm8,[rsp]
mov [rsp],(float)0.15
movss xmm10,[rsp]
add rsp,04
jmp fireRateCrouchRet
@@:
movss xmm6,[r8+4C]
movss xmm10,[r8+50]
movss xmm8,[r8+54]
jmp fireRateCrouchRet

get_fireRateStanding:
  jmp fireRateStanding
  nop d
fireRateStandingRet:
registersymbol(get_fireRateStanding)

get_fireRateCrouch:
  jmp fireRateCrouch
  nop d
fireRateCrouchRet:
registersymbol(get_fireRateCrouch)

[DISABLE]
get_fireRateStanding:
  db F3 45 0F 10 40 48 F3 45 0F 10 50 44 F3 41 0F 10 70 40

get_fireRateCrouch:
  db F3 45 0F 10 40 54 F3 45 0F 10 50 50 F3 41 0F 10 70 4C

unregistersymbol(get_fireRateStanding)
unregistersymbol(get_fireRateCrouch)
dealloc(fireRateStanding)
dealloc(fireRateCrouch)

{$lua}
writeByte('isActive',00)
{$asm}

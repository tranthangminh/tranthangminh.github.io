    <CheatEntry>
      <ID>16353</ID>
      <Description>"SOURCE: https://fearlessrevolution.com/viewtopic.php?t=18171"</Description>
      <Options moManualExpandCollapse="1" moActivateChildrenAsWell="1" moDeactivateChildrenAsWell="1" moAllowManualCollapseAndExpand="1"/>
      <LastState/>
      <Color>40BF40</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>[ENABLE]
{$lua}
shellExecute("https://fearlessrevolution.com/viewtopic.php?t=18171")
{$asm}

[DISABLE]
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>27</ID>
          <Description>"[[ ENABLE ]]"</Description>
          <Options moHideChildren="1" moManualExpandCollapse="1" moAllowManualCollapseAndExpand="1"/>
          <LastState/>
          <Color>FF8000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">[ENABLE]
{$lua}
get_Time = AOBScanModuleUnique('SanAndreas.exe','FE C0 44 88 * * * * * 88')
local x1, x2, x3, x4 = splitDisassembledString(disassemble('get_Time+2'))
registerSymbol('timeMinutes',x2:match("%x+"))
local x1, x2, x3, x4 = splitDisassembledString(disassemble('get_Time+9'))
registerSymbol('timeHours',x2:match("%x+"))
{$asm}
//
aobscanmodule(GiveWeapon,SanAndreas.exe,4C 8B DC 55 56 41 54 41 57 49 8D AB)
registersymbol(GiveWeapon)
aobscanmodule(SetWantedLevel,SanAndreas.exe,80 3D * * * * 00 4C 8B C1 0F 85 * * * * 3B)
registersymbol(SetWantedLevel)
aobscanmodule(SpawnVehicle,SanAndreas.exe,40 56 57 41 57 48 83 EC 40 0F)
registersymbol(SpawnVehicle)
//
aobscanmodule(get_playerVehicle,SanAndreas.exe,B6 D1 48 8B 03 48 8B CB)
aobscanmodule(get_Player,SanAndreas.exe,48 8B 82 88 05 00 00 F6 40 48 08 74)
aobscanmodule(get_selNPC,SanAndreas.exe,48 8B 01 FF 90 C0 00 00 00 83 F8 03)
aobscanmodule(get_CJStats,SanAndreas.exe,00 83 F8 52 73 0B F3 0F 10 * * * * * * EB)
aobscanmodule(get_wantedLevel,SanAndreas.exe,48 8B 4C 18 08 83 79 2C 04)
aobscanmodule(get_Waypoint,SanAndreas.exe,F3 44 0F 10 4C C8 08 F3)
aobscanmodule(get_vehColor,SanAndreas.exe,30 42 0F B6 8C 10 50 06 00 00)
aobscanmodule(get_allCarsHaveNitro,SanAndreas.exe,44 38 2D * * * * 75 05)
registersymbol(get_allCarsHaveNitro)
alloc(fWaypoint,$1000,get_Waypoint)
alloc(fvehColor,$1000,get_vehColor)
registersymbol(get_CJStats)
alloc(CJStats,10)
registersymbol(CJStats)
alloc(newmem,$1000,get_playerVehicle)
alloc(fPlayer,$1000,get_Player)
alloc(fselNPC,$1000,get_selNPC)
alloc(fwantedLevel,$1000,get_wantedLevel)
label(return)
label(fPlayerRet)
label(fPlayerExit)
label(fselNPCRet)
label(fwantedLevelRet)
label(fvehColorRet)
label(PushTime)
label(PopTime)
alloc(playerVehicle,8)
alloc(Player,8)
alloc(selNPC,8)
alloc(Waypoint,8)
alloc(wantedLevel,8)
alloc(freezeLevel,8)
alloc(desiredWeapon,2)
alloc(veh2Spawn,2)
alloc(Cheats,5)
alloc(dWantedLevel,1)
alloc(runSetWantedLevel,1)
alloc(get_allCarsHaveNitroS,7)
globalalloc(isActive,1)
globalalloc(vehColor,2)
registersymbol(playerVehicle)
registersymbol(Player)
registersymbol(selNPC)
registersymbol(Waypoint)
registersymbol(desiredWeapon)
registersymbol(veh2Spawn)
registersymbol(Cheats)
registersymbol(dWantedLevel)
registersymbol(wantedLevel)
registersymbol(freezeLevel)
registersymbol(runSetWantedLevel)
registersymbol(setWantedLevel)
registersymbol(get_allCarsHaveNitroS)

CJStats:
readmem(get_CJStats+B,4)
dd 0
readmem(get_CJStats+16,4)
dd 0
wantedLevel:
readmem(get_wantedLevel+5,4)
dd 0
freezeLevel:
readmem(SetWantedLevel+2,4)
dd 0
vehColor+1:
db 7F
get_allCarsHaveNitroS:
readMem(get_allCarsHaveNitro,7)

newmem:
mov rax,playerVehicle
mov [rax],rbx
mov rax,[rbx]
mov rcx,rbx
jmp return

fPlayer:
cmp byte ptr [Cheats],01
jne @f
mov byte ptr [Cheats],00
cmp [desiredWeapon],0
je fPlayerExit
cmp [selNPC],0
je fPlayerExit
call PushTime
mov rcx,[selNPC]
mov edx,[desiredWeapon]
xor r8,r8
sub rsp,30
and spl,F0
call GiveWeapon
call PopTime
@@:
cmp byte ptr [Cheats+2],01
jne @f
mov byte ptr [Cheats+2],00
call PushTime
mov byte ptr [runSetWantedLevel],01
mov rcx,[wantedLevel]
xor rdx,rdx
mov dl,[dWantedLevel]
sub rsp,30
and spl,F0
call SetWantedLevel
mov byte ptr [runSetWantedLevel],00
call PopTime
@@:
cmp byte ptr [Cheats+4],01
jne @f
mov byte ptr [Cheats+4],00
cmp byte ptr [veh2Spawn],00
je fPlayerExit //If vehicle not selected, skip. Otherwise it'll crash due to missing parameter.
call PushTime
mov rcx,vehColor
mov byte ptr [rcx],01
xor rcx,rcx
mov r8,19F
mov cx,[veh2Spawn]
mov rdx,[Player]
sub rsp,30
and spl,F0
call SpawnVehicle //Returns Spawned Vehicle Pointer
call PopTime
@@:
fPlayerExit:
mov rax,Player
mov [rax],rdx
mov rax,[rdx+00000588]
jmp fPlayerRet

fselNPC:
mov rax,selNPC
mov [rax],rcx
mov rax,[rcx]
call qword ptr [rax+000000C0]
jmp fselNPCRet

fWaypoint:
push rbx
lea rbx,[rax+rcx*8+08]
mov [Waypoint],rbx
cmp byte ptr [Cheats+1],00
je @f
mov byte ptr [Cheats+1],00
push rdx
mov rdx,Player
mov rdx,[rdx]
mov rdx,[rdx+18]
mov ebx,[rax+rcx*8+08]
mov [rdx+30],ebx
mov ebx,[rax+rcx*8+0C]
mov [rdx+34],ebx
mov ebx,[rax+rcx*8+10]
sub rsp,08
mov [rsp],ebx
mov ebx,404A00000 //Just in case
mov [rsp+04],ebx
fld [rsp]
fld [rsp+04]
faddp
fstp [rsp]
mov ebx,[rsp]
add rsp,08
mov [rdx+38],ebx
pop rdx
@@:
pop rbx
movss xmm9,[rax+rcx*8+08]
jmp fWaypointRet

fwantedLevel:
mov rcx,[rax+rbx+08]
mov [wantedLevel],rcx
jmp fwantedLevelRet

fvehColor:
push rbx
mov rbx,vehColor
cmp byte ptr [rbx],00
je @f
cmp byte ptr [rbx+1],7F //Default Game Choice
je @f
mov cl,[rbx+1]
mov byte ptr [rbx],00
pop rbx
jmp fvehColorRet
@@:
mov byte ptr [rbx],00
pop rbx
movzx ecx,byte ptr [rax+r10+00000650]
jmp fvehColorRet

PushTime:
push rax
push rbx
push rcx
push rdx
push rsi
push rdi
push r8
push r9
push r10
push r11
push r12
push r13
push r14
push r15
push rbp
mov rbp,rsp
jmp [rsp+78]

PopTime:
mov rax,[rsp]
mov rsp,rbp
mov [rsp+78],rax
pop rbp
pop r15
pop r14
pop r13
pop r12
pop r11
pop r10
pop r9
pop r8
pop rdi
pop rsi
pop rdx
pop rcx
pop rbx
pop rax
ret

get_playerVehicle+02:
  jmp newmem
  nop
return:
registersymbol(get_playerVehicle)

get_Player:
  jmp fPlayer
  nop 2
fPlayerRet:
registersymbol(get_Player)

get_selNPC:
  jmp fselNPC
  nop 4
fselNPCRet:
registersymbol(get_selNPC)

get_Waypoint:
  jmp fWaypoint
  nop 2
fWaypointRet:
registersymbol(get_Waypoint)

get_wantedLevel:
  jmp fwantedLevel
fwantedLevelRet:
registersymbol(get_wantedLevel)

get_vehColor+01:
  jmp fvehColor
  nop 4
fvehColorRet:
registersymbol(get_vehColor)

[DISABLE]
get_playerVehicle+02:
  db 48 8B 03 48 8B CB

get_Player:
  db 48 8B 82 88 05 00 00

get_selNPC:
  db 48 8B 01 FF 90 C0 00 00 00

get_Waypoint:
  db F3 44 0F 10 4C C8 08

get_wantedLevel:
  db 48 8B 4C 18 08

get_vehColor+01:
  db 42 0F B6 8C 10 50 06 00 00

unregistersymbol(get_playerVehicle)
unregistersymbol(get_Player)
unregistersymbol(get_selNPC)
unregistersymbol(get_Waypoint)
unregistersymbol(get_wantedLevel)
unregistersymbol(get_vehColor)
dealloc(newmem)
dealloc(fPlayer)
dealloc(fselNPC)
dealloc(fWaypoint)
dealloc(fwantedLevel)
dealloc(fvehColor)


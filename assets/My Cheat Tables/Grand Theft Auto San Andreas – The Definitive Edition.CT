                <CheatEntry>
                  <ID>297</ID>
                  <Description>"Activate Radio Anywhere [Hotkey: F2] (Scuffy)"</Description>
                  <LastState/>
                  <Color>8000FF</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
//Kind of scuffed, but works. So it's fine I guess.
aobscanmodule(get_activateRadio,SanAndreas.exe,80 BB CD 00 00 00 00 0F 84 CD)
aobscanmodule(get_Bool,SanAndreas.exe,40 84 ED 0F 84 81 00 00 00)
registersymbol(get_Bool)
alloc(newmem,$1000,get_activateRadio)
label(code)
label(return)

newmem:
xor r8,r8
cmp byte ptr [Cheats+3],00
je code
mov byte ptr [Cheats+3],00
cmp qword ptr [SanAndreas.exe+4FF2380],0
je @f
mov qword ptr [SanAndreas.exe+4FF2380],0
jmp code
@@:
mov r8l,01
code:
cmp byte ptr [rbx+000000CD],00
jmp return

get_activateRadio:
  jmp newmem
  nop 2
return:
registersymbol(get_activateRadio)

get_Bool:
db 45 84 C0

[DISABLE]
get_activateRadio:
  db 80 BB CD 00 00 00 00

get_Bool:
db 40 84 ED

unregistersymbol(get_activateRadio)
dealloc(newmem)

{

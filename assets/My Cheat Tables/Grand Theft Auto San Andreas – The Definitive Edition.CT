get_damageExplode:
db F3 0F 11 5C 24 20

unregistersymbol(get_vehicleDamage1)
unregistersymbol(get_vehicleDamage2)
unregistersymbol(get_damageWhenFlipped)
unregistersymbol(get_damageExplode)

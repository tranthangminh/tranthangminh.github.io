//Distance
define(addressDistance,Level:UpdateLevel+1093)

//Combo
define(addressCombo,1FC980F06D0)






[ENABLE]

//──────────────────────────────────────── Distance

alloc(newmemDistance,$1000,Level:UpdateLevel+1093)

alloc(Distance,8)
registersymbol(Distance)
label(codeDistance)
label(returnDistance)

newmemDistance:

codeDistance:
 mov [Distance],rsi //Save rsi address into Distance
 movss xmm0,[rsi+000001EC]
 jmp returnDistance

addressDistance:
 jmp newmemDistance
 nop 3
returnDistance:

//──────────────────────────────────────── Combo

alloc(newmemCombo,$1000,1FC980F06D0)

alloc(Combo,8)
registersymbol(Combo)
label(codeCombo)
label(returnCombo)

newmemCombo:

codeCombo:
 mov [Combo],r15 //Save r15 address into Combo
 movsxd rax,dword ptr [r15+000001FC]
 jmp returnCombo

addressCombo:
 jmp newmemCombo
 nop 2
returnCombo:







[DISABLE]

//──────────────────────────────────────── Distance

addressDistance:
 movss xmm0,[rsi+000001EC]

dealloc(newmemDistance)
dealloc(Distance)
unregistersymbol(Distance)

//──────────────────────────────────────── Combo

addressCombo:
 movsxd rax,dword ptr [r15+000001FC]

dealloc(newmemCombo)
dealloc(Combo)
unregistersymbol(Combo)
</AssemblerScript>
